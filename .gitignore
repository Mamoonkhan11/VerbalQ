# ============================================
# ROOT .gitignore for VerbalQ Project
# ============================================

# Dependencies (all services)
node_modules/
frontend/node_modules/
backend/node_modules/
ml-service/__pycache__/
ml-service/.venv/
ml-service/venv/

# Build outputs
build/
dist/
.next/
out/
frontend/.next/
frontend/out/

# Environment files (.env should NEVER be committed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.*
frontend/.env*
frontend/.env.local
ml-service/.env
ml-service/.env.*
!.env.example
!backend/.env.example
!frontend/.env.example
!ml-service/.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
tmp/
temp/
.cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Python specific
__pycache__/
*.py[cod]
*$py.class
.Python
pip-log.txt
.tox/
.coverage
.mypy_cache/
.pytest_cache/
.hypothesis/

# Database
*.lock
*.sock

# Authentication keys (NEVER commit these!)
*.pem
*.key
*.crt
*.p12
*.pfx

# Render deployment configs (if using manual configs)
render-backup-*/

# ngrok (don't commit ngrok config)
.ngrok

# ML model files (large binaries)
ml-service/models/*.pth
ml-service/models/*.pt
ml-service/models/*.h5
ml-service/checkpoints/
ml-service/ollama_data/
ml-service/.ollama/

# Jupyter notebooks (optional)
.ipynb_checkpoints

# Vercel
.vercel